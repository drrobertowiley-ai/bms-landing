# =====================================================================
# BMS Landing — variables de entorno (ejemplo)
# =====================================================================
# Copia este archivo a `.env.local` para desarrollo, o configura los
# mismos valores en el dashboard de Vercel para producción.
#
# Todas las variables aquí son OPCIONALES: si no se definen, los scripts
# de tracking simplemente no se cargan y la página sigue funcionando.
# =====================================================================

# --- Tracking de marketing -------------------------------------------

# Google Analytics 4 — Measurement ID
# Formato: G-XXXXXXXXXX
# Donde sacarlo: https://analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA4_ID=

# Meta (Facebook) Pixel ID
# Formato: 15-16 dígitos, ej. 1234567890123456
# Donde sacarlo: https://business.facebook.com → Events Manager
NEXT_PUBLIC_META_PIXEL_ID=

# LinkedIn Insight Tag — Partner ID
# Formato: 6-7 dígitos, ej. 1234567
# Donde sacarlo: https://www.linkedin.com/campaignmanager → Account Assets → Insight Tag
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# --- Otros (futuro) --------------------------------------------------

# URL canónica del sitio (usada como base para metadata, sitemap, OG).
# En producción Vercel ya provee NEXT_PUBLIC_VERCEL_URL automáticamente.
NEXT_PUBLIC_SITE_URL=https://bms.services
